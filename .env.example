NEXT_PUBLIC_APP_NAME=Habitos Local First

# Client ID publico de Google Identity Services.
# Crear en Google Cloud Console como OAuth Client ID de tipo Web.
NEXT_PUBLIC_GOOGLE_CLIENT_ID=

# Activa la pantalla de login aunque falte el Client ID.
NEXT_PUBLIC_REQUIRE_GOOGLE_LOGIN=false

# Opcional: lista de emails permitidos, separados por coma.
# Al ser una app estatica, esta lista es una barrera de interfaz, no seguridad fuerte.
NEXT_PUBLIC_ALLOWED_GOOGLE_EMAILS=
